# ==============================================================================
# AUTO-CONVERT CONFIGURATION
# ==============================================================================
# Copy this file to .env and customize for your setup
# All settings are optional - sensible defaults are provided


# ==============================================================================
# DIRECTORY SETTINGS
# ==============================================================================

# Local directory containing your music files (host path)
MUSIC_DIR=./music

# Output directory for converted files (host path)
# If same as MUSIC_DIR, files will be created alongside originals
OUTPUT_DIR=./output
# Internal watch directory (container path - usually no need to change)
WATCH_DIR=/watch

# Internal output directory (container path - usually no need to change)
# OUTPUT_DIR=/watch


# ==============================================================================
# CONVERSION SETTINGS
# ==============================================================================

# Input file format to watch for (without dot)
# Examples: flac, mp3, wav, m4a, ogg, opus
INPUT_FORMAT=flac

# Output file format
# Examples: aiff, wav, flac, mp3, m4a
OUTPUT_FORMAT=aiff

# Audio codec for output
# Common options:
#   - pcm_s16le (16-bit PCM, best for CDJs)
#   - pcm_s24le (24-bit PCM, higher quality)
#   - pcm_s32le (32-bit PCM, maximum quality)
#   - aac (for m4a output)
#   - libmp3lame (for mp3 output)
AUDIO_CODEC=pcm_s16le

# Sample rate in Hz
# CDJ standard: 44100
# High-res: 48000, 96000, 192000
SAMPLE_RATE=44100

# Bit depth (8, 16, 24, or 32)
# CDJ standard: 16
# Professional: 24
BIT_DEPTH=16


# ==============================================================================
# BEHAVIOR SETTINGS
# ==============================================================================

# Watch subdirectories recursively (true/false)
RECURSIVE=true

# Preserve all metadata (tags, album art, BPM, key, etc.)
# Highly recommended for DJ use
PRESERVE_METADATA=true

# Delete source file after successful conversion (true/false)
# WARNING: Use with caution!
DELETE_SOURCE=false

# Process files that already exist when container starts (true/false)
PROCESS_EXISTING=true

# Time in seconds to wait after file write before processing
# Ensures file is completely written (especially important for large files)
# Increase if you experience incomplete conversions
FILE_STABLE_TIME=2


# ==============================================================================
# LOGGING
# ==============================================================================

# Log level: debug, info, error
# debug: Very verbose, shows every operation
# info: Normal verbosity, shows conversions
# error: Only show errors
LOG_LEVEL=info
